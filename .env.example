# 複製此檔為 .env 並填入你的設定

# ngrok Auth Token（免費帳號即可）
# 取得：https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=

# ~/.claude 路徑（Windows 用正斜線，把 你的名字 換成你的 Windows 使用者名稱）
CLAUDE_HOME=C:/Users/你的名字/.claude

# ~/.codex 路徑——選用，只有想在容器裡使用 Codex CLI 引擎才需要填。
# 沒有先 `codex login` 過的話，容器裡的 Codex 一律會顯示成「未登入」，
# 引擎選單會自動切回 Claude。
CODEX_HOME=C:/Users/你的名字/.codex

# Codex 與其他 Agent 工具共用的 Skills 根目錄（內含 skills/ 子目錄）。
AGENTS_HOME=C:/Users/你的名字/.agents
# Docker host port for the backend. The container and nginx upstream still use
# 8765; 8760 avoids Windows/Hyper-V excluded ranges that can include 8765.
BACKEND_HOST_PORT=8760
