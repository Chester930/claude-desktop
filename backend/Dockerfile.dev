FROM python:3.11-slim

RUN apt-get update && apt-get install -y curl && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

RUN npm install -g @anthropic-ai/claude-code @openai/codex

# docker.sock is bind-mounted in (docker-compose.yml) so this container can
# reach the host's Docker daemon, but nothing here was ever installed to
# actually talk to it — handle_mcp_action() in main.py shells out to
# `docker`/`docker compose` for docker-type MCP servers' start/stop/restart
# and the Docker-config UI, and those calls fail with "command not found"
# without a client. Copying just the CLI (+ compose v2 plugin) from the
# official image is much lighter than installing the full Docker Engine.
COPY --from=docker:27-cli /usr/local/bin/docker /usr/local/bin/docker
COPY --from=docker:27-cli /usr/local/libexec/docker/cli-plugins/docker-compose /usr/local/libexec/docker/cli-plugins/docker-compose

# Same story as docker above: the "fetch"/"sqlite" preset MCP servers
# (backend/main.py) are registered as `uvx mcp-server-fetch` / `uvx
# mcp-server-sqlite ...`, but uvx was never installed — both fail with
# "command not found". Official Astral pattern for including uv in an
# image: copy the prebuilt binaries straight from their image.
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /usr/local/bin/

WORKDIR /app
COPY requirements.txt .
# nvidia-cublas-cu12 / nvidia-cudnn-cu12 (optional GPU accelerators — stt.py
# falls back to CPU silently without them) are each several hundred MB+ and
# have been the repeated point of failure on this machine's current flaky
# connection to files.pythonhosted.org. Installed in a separate layer so a
# transient failure here doesn't force redownloading everything else, and
# skippable entirely for dev sessions that don't need GPU-accelerated STT.
RUN grep -v '^nvidia-' requirements.txt > requirements.core.txt && \
    pip install --no-cache-dir --timeout 120 --retries 10 -r requirements.core.txt "watchdog[watchmedo]"
RUN pip install --no-cache-dir --timeout 120 --retries 10 nvidia-cublas-cu12 nvidia-cudnn-cu12 || \
    echo "[dev build] Skipping optional GPU accelerators (nvidia-cublas-cu12/nvidia-cudnn-cu12) — STT will run on CPU."

EXPOSE 8765

# 掛載 ./backend 為 volume 後，watchmedo 偵測到 .py 異動即自動重啟
CMD ["sh", "/app/docker-entrypoint.sh", "python", "-u", "/app/watcher.py"]
